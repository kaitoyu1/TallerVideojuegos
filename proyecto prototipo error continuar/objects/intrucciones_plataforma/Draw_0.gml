draw_set_font(Font1)
draw_set_color(c_white)
draw_set_halign(fa_center)
draw_set_valign(fa_middle)

draw_text(room_width/2, room_height/2 ,"En el siguiente nivel vas a tener que saltar \npor plataformas hasta llegar a la cima\n para saltar se tiene que apretar el espacio.\n Para continuar presione Enter.")
